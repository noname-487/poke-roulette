<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>포켓몬 버전별 4단계 룰렛</title>
    <link rel="stylesheet" href="style.css">
    
    <style>

    </style>
</head>
<body>

<div class="container">
    <h1>🎡 포켓몬 버전별 4단계 순차 룰렛</h1>
    
    <div class="version-area">
        <label style="font-weight: bold; display: block; margin-bottom: 5px;">🎮 플레이할 버전 선택</label>
        <select id="versionSelect" onchange="onChangeMainVersion()">
            <option value="">-- 게임 본편을 선택해주세요 --</option>
            <option value="파레리그">파이어레드/리프그린</option>
            <option value="하골소실">하트골드/소울실버</option>
            <option value="오루알사">오메가루비/알파사파이어</option>
			<option value="브다샤펄">브릴리언트 다이아몬드/샤이닝 펄</option>
			<option value="블화2">블랙2/화이트</option>
            <option value="엑스와이">엑스/와이</option>
            <option value="울썬문">울트라썬/울트라문</option>
            <option value="소드실드">소드/실드</option>
            <option value="스바">스칼렛/바이올렛</option>
        </select>
        
        <div id="optionContainer" style="display: none;">
            <div class="option-toggle-zone">
                <div>
                    <span style="font-size: 12px; color: #555; display: block; margin-bottom: 2px;">➕ DLC 확장 도감 추가</span>
                    <div class="dlc-checkbox-group" id="dlcCheckboxZone"></div>
                </div>
                
                <div class="rarity-toggle">
                    <span style="font-size: 12px; color: #555; display: block; margin-bottom: 2px;">⚡ 특수 포켓몬 제한</span>
                    <label><input type="checkbox" id="rarityCheck" onchange="calculatePreviewCount()"> ⭐ 전설/환상 포함</label>
                </div>
            </div>
        </div>
        
        <button id="btn-confirm-version" onclick="lockAndLoadDatabase()" disabled>선택한 조건으로 데이터 확정하기</button>
    </div>

    <div class="step-container">
        <div class="step-box" id="box-gen">
            <div class="step-title">1단계: 세대</div>
            <div class="step-result" id="res-gen">? 세대</div>
        </div>
        <div class="step-box" id="box-type">
            <div class="step-title">2단계: 타입</div>
            <div class="step-result" id="res-type">? 타입</div>
        </div>
        <div class="step-box" id="box-poke">
            <div class="step-title">3단계: 포켓몬</div>
            <div class="step-result" id="res-poke">? 마리</div>
        </div>
    </div>

    <div class="wheel-area">
        <div class="wheel-pointer">▼</div>
        <canvas id="wheelCanvas" width="500" height="500"></canvas>
    </div>

    <div class="current-pointing-word" id="livePointerText"><span>-</span></div>

    <div class="font-control-area">
        <button class="font-ctrl-btn" onclick="adjustFontSize(-1)">−</button>
        <div class="font-size-indicator" id="fontSizeLabel">룰렛 글자 크기: 100%</div>
        <button class="font-ctrl-btn" onclick="adjustFontSize(1)">+</button>
    </div>

    <div class="final-box">
        <div id="final-name">준비 완료</div>
        <div id="final-info">먼저 상단에서 게임 버전을 선택해 주세요!</div>
    </div>

    <div class="btn-group">
        <button id="btn-gen" onclick="startGenSpin()" disabled>1. 세대 돌리기</button>
        <button id="btn-type" onclick="startTypeSpin()" disabled>2. 타입 돌리기</button>
        <button id="btn-poke" onclick="startPokeSpin()" disabled>3. 포켓몬 돌리기</button>
        <button id="btn-reset" onclick="resetAll()">리셋</button>
    </div>

    <div class="debug-control-zone">
        <button type="button" id="btn-toggle-debug" class="toggle-btn" onclick="toggleDebugMonitor()">🛠️ 피카츄 켜기</button>
        <div id="debug-container" style="display: none; margin-top: 15px;">
            <div id="debug-status" style="font-weight: bold; font-size: 12px; margin-bottom: 5px; color: #64748b;">🟢 준비 대기 중</div>
            <canvas id="debugCanvas" width="120" height="120" style="border: 2px dashed #cbd5e1; border-radius: 8px; background: #fff; margin: 0 auto; display: block;"></canvas>
        </div>
    </div>

    <div class="custom-editor-area" id="editorPanel" style="display: none;">
        <div class="editor-title">
            <span>🎡 현재 단계 룰렛 항목 & 비중(가중치) 직접 편집</span>
            <span id="editorModeBadge" style="font-size:11px; color:#fff; background:#868e96; padding:2px 6px; border-radius:4px;">대기중</span>
        </div>
        <div class="add-item-row">
            <input type="text" id="newInputText" placeholder="새로운 항목 이름 입력...">
            <button onclick="addItemToEditor()">+ 추가</button>
        </div>
        <div class="item-list-container" id="editorItemsContainer">
        </div>
    </div>
</div>

<footer class="site-footer">
    <div class="footer-header">
        <p style="margin: 0 0 5px 0; font-weight: bold; color: #475569; text-align: center;">&copy; 2026 포켓몬 룰렛. Powered by PokéRogue Assets.</p>
        <button type="button" id="btn-toggle-footer" class="footer-toggle-btn" onclick="toggleFooterDetails()">📄 법적 면책 조항 및 출처 보기 (▼)</button>
    </div>
    
    <div id="footer-details" class="footer-content" style="display: none;">
        <div class="footer-section ko">
            <h3>면책 조항 (Disclaimer)</h3>
            <p>본 사이트는 개인이 취미로 운영하는 <strong>비공식 팬 사이트</strong>이며, 어떠한 상업적 이익도 추구하지 않습니다. 포켓몬스터(Pokémon) 및 관련된 모든 캐릭터, 명칭, 이미지, 사운드의 저작권과 상표권은 원저작권자인 <strong>Nintendo, Creatures Inc., GAME FREAK Inc., 및 The Pokémon Company</strong>에 있습니다. 본 사이트는 원저작권자의 권리를 침해할 의도가 없으며, 원저작권자의 요청이 있을 경우 관련 콘텐츠는 즉시 삭제될 수 있습니다.</p>
            
            <h3>출처 표기 (Attribution)</h3>
            <p>본 사이트에 사용된 일부 도트 그래픽 및 사운드 에셋은 <strong>PokéRogue 개발팀(pagefaultgames)</strong> 및 기여자들에 의해 제작되었으며, <strong>CC-BY-NC-SA 4.0</strong> 라이선스에 따라 출처를 밝히고 사용되었습니다. 원본 에셋 저장소는 <a href="https://github.com/pagefaultgames/pokerogue-assets" target="_blank" rel="noopener noreferrer">여기(GitHub)</a>에서 확인하실 수 있습니다.</p>
        </div>
        
        <div class="footer-section en">
            <h3>Disclaimer</h3>
            <p>This is an <strong>unofficial, fan-made website</strong> operated strictly for non-commercial purposes. Pokémon and all related characters, names, images, and audio are trademarks and copyrights of <strong>Nintendo, Creatures Inc., GAME FREAK Inc., and The Pokémon Company</strong>. No copyright infringement is intended. This website is not affiliated with, endorsed, or sponsored by the official rights holders, and will be promptly removed upon request.</p>
            
            <h3>Attribution</h3>
            <p>Certain graphic and audio assets used on this website are sourced from the <a href="https://github.com/pagefaultgames/pokerogue-assets" target="_blank" rel="noopener noreferrer">PokéRogue repository (pagefaultgames)</a> and its contributors, utilized under the <strong>CC-BY-NC-SA 4.0</strong> license.</p>
        </div>
    </div>
</footer>

<script src="pokemonData.js"></script> 
<script>
const canvas = document.getElementById("wheelCanvas");
const ctx = canvas.getContext("2d");

let chosenMainVersion = "";
let versionFilteredDB = [];

let currentItems = []; 
let currentAngle = 0;
let isSpinning = false;
let mode = "NONE"; 

let chosenGen = null;
let chosenType = null;
let finalCandidates = [];

let fontScale = 1.0;

// 스프라이트 시트 애니메이션 제어용 전역 변수
let currentSpriteImage = null;
let currentSpriteFrames = [];
let currentSpriteFrameIndex = 0;
let lastFrameTime = 0;
const frameDuration = 100; 

// 🎉 당첨 축포(콘페티) 효과 제어용 전역 변수
let confettiParticles = [];

// 디버그 전용 파이프라인 제어 변수
let debugImage = null;
let debugFrames = [];
let debugFrameIndex = 0;
let debugLastTime = 0;

const colors = ["#ffadad", "#ffd6a5", "#fdffb6", "#caffbf", "#9bf6ff", "#a0c4ff", "#bdb2ff", "#ffc6ff"];

const typeColors = {
    "노말": "#b5b5a8", "불꽃": "#fca678", "물": "#90b0f8", "풀": "#9cd89c", "전기": "#fce078",
    "얼음": "#b0e0e0", "격투": "#dc7870", "독": "#c878c8", "땅": "#ebd090", "비행": "#c0b0f8",
    "에스퍼": "#fca0b8", "벌레": "#c0d058", "바위": "#d0c078", "고스트": "#a090d8", "드래곤": "#a080f8",
    "악": "#908078", "강철": "#d0d0e0", "페어리": "#f0b8f0"
};

const typeTextColors = {
    "노말": "#4a4a40", "불꽃": "#5e2608", "물": "#0f2861", "풀": "#144014", "전기": "#4d4008",
    "얼음": "#104040", "격투": "#4a120e", "독": "#401040", "땅": "#4d3d14", "비행": "#24145e",
    "에스퍼": "#5e0820", "벌레": "#333d08", "바위": "#403710", "고스트": "#22144a", "드래곤": "#200461",
    "악": "#2e2522", "강철": "#3c3c4a", "페어리": "#4a104a"
};

// 페이지 로드 즉시 피카츄 자산 파싱 검증 구동
window.addEventListener("DOMContentLoaded", () => {
    initDebugMonitor();
});

function initDebugMonitor() {
    const pikachuNo = 25; 
    const jsonUrl = `pokerogue-asset/images/pokemon/${pikachuNo}.json`;
    const pngUrl = `pokerogue-asset/images/pokemon/${pikachuNo}.png`;
    const statusEl = document.getElementById("debug-status");

    if (window.location.protocol === 'file:') {
        statusEl.innerText = "❌ 로컬서버(Live Server) 실행 필요";
        statusEl.style.color = "#ef4444";
        return;
    }

    fetch(jsonUrl)
        .then(res => {
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            return res.json();
        })
        .then(data => {
            let frames = [];
            if (data.textures && data.textures[0] && data.textures[0].frames) {
                const f = data.textures[0].frames;
                frames = Array.isArray(f) ? f : Object.values(f);
            } else if (data.frames) {
                frames = Array.isArray(data.frames) ? data.frames : Object.values(data.frames);
            }
            
            if (!frames || frames.length === 0) {
                statusEl.innerText = "❌ 프레임 파싱 실패";
                statusEl.style.color = "#ef4444";
                return;
            }
            
            frames.sort((a, b) => String(a.filename).localeCompare(String(b.filename)));
            
            const img = new Image();
            img.onload = () => {
                debugImage = img;
                debugFrames = frames;
                debugFrameIndex = 0;
                debugLastTime = performance.now();
                statusEl.innerText = `🟢 피카츄 로드 완료 (${frames.length}F)`;
                statusEl.style.color = "#4ade80";
                animateDebugFrame();
            };
            img.src = pngUrl;
        })
        .catch(err => {
            statusEl.innerText = `❌ 에러: 경로 확인 필요`;
            statusEl.style.color = "#ef4444";
        });
}

function animateDebugFrame() {
    requestAnimationFrame(animateDebugFrame);
    if (!debugImage || debugFrames.length === 0) return;

    const now = performance.now();
    if (now - debugLastTime > frameDuration) {
        debugFrameIndex = (debugFrameIndex + 1) % debugFrames.length;
        debugLastTime = now;

        const dCanvas = document.getElementById("debugCanvas");
        if (!dCanvas) return;
        const dCtx = dCanvas.getContext("2d");
        dCtx.clearRect(0, 0, dCanvas.width, dCanvas.height);

        const currentFrame = debugFrames[debugFrameIndex];
        if (!currentFrame || !currentFrame.frame) return;

        const f = currentFrame.frame;
        const scale = 2.5; 
        const tw = f.w * scale;
        const th = f.h * scale;
        const dx = (dCanvas.width - tw) / 2;
        const dy = (dCanvas.height - th) / 2;

        dCtx.drawImage(debugImage, f.x, f.y, f.w, f.h, dx, dy, tw, th);
    }
}

// 🔊 울음소리 재생 시스템
function playPokemonCry(pokemonNo) {
    if (!pokemonNo) return;
    
    const cleanNo = String(pokemonNo).replace(/[^0-9]/g, '');
    if (!cleanNo) return;
    
    const num = parseInt(cleanNo, 10);
    const formats = [cleanNo]; 
    if (!isNaN(num)) {
        formats.push(String(num)); 
        formats.push(String(num).padStart(3, '0')); 
        formats.push(String(num).padStart(4, '0')); 
    }
    
    const uniqueFormats = [...new Set(formats)];
    const extensions = ['m4a', 'ogg', 'mp3', 'wav'];
    let combinations = [];
    
    uniqueFormats.forEach(f => {
        extensions.forEach(ext => {
            combinations.push({ id: f, ext: ext });
        });
    });
    
    let comboIndex = 0;
    
    function tryPlay() {
        if (comboIndex >= combinations.length) {
            console.warn(`[오디오 오류] 도감번호 ${pokemonNo}의 울음소리를 찾을 수 없습니다.`);
            return;
        }
        
        const combo = combinations[comboIndex];
        const audioUrl = `pokerogue-asset/audio/cry/${combo.id}.${combo.ext}`;
        const audio = new Audio(audioUrl);
        audio.volume = 0.4;
        
        audio.play()
            .then(() => {
                console.log(`🔊 울음소리 재생 성공: ${audioUrl}`);
            })
            .catch(() => {
                comboIndex++;
                tryPlay();
            });
    }
    
    tryPlay();
}

function adjustFontSize(direction) {
    fontScale += direction * 0.1;
    if (fontScale < 0.5) fontScale = 0.5;
    if (fontScale > 2.0) fontScale = 2.0;
    document.getElementById("fontSizeLabel").innerText = `글자 크기: ${Math.round(fontScale * 100)}%`;
    drawWheel();
}

function getTotalWeight() {
    return currentItems.reduce((sum, item) => sum + item.weight, 0);
}

function getTargetIndex() {
    const numSegments = currentItems.length;
    if (numSegments === 0) return -1;
    const totalW = getTotalWeight();
    if (totalW === 0) return -1;

    let normalizedAngle = (1.5 * Math.PI - currentAngle) % (2 * Math.PI);
    if (normalizedAngle < 0) normalizedAngle += 2 * Math.PI;

    const angleRatio = normalizedAngle / (2 * Math.PI);
    let accumulatedRatio = 0;

    for (let i = 0; i < numSegments; i++) {
        const itemRatio = currentItems[i].weight / totalW;
        accumulatedRatio += itemRatio;
        if (angleRatio <= accumulatedRatio) {
            return i;
        }
    }
    return numSegments - 1;
}

function updateLivePointerText() {
    const idx = getTargetIndex();
    if (idx !== -1 && currentItems[idx]) {
        document.getElementById("livePointerText").innerHTML = `<span>${currentItems[idx].text}</span>`;
    } else {
        document.getElementById("livePointerText").innerHTML = `<span>-</span>`;
    }
}

function drawWheel() {
    const numSegments = currentItems.length;
    if (numSegments === 0) { ctx.clearRect(0, 0, canvas.width, canvas.height); return; }
    
    const totalW = getTotalWeight();
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.save();
    ctx.translate(canvas.width / 2, canvas.height / 2);
    ctx.rotate(currentAngle);
    
    let currentStartAngle = 0;
    
    for (let i = 0; i < numSegments; i++) {
        const item = currentItems[i];
        const itemText = item.text;
        const arcSize = (item.weight / totalW) * (2 * Math.PI);
        
        ctx.beginPath();
        ctx.moveTo(0, 0);
        ctx.arc(0, 0, canvas.width / 2 - 8, currentStartAngle, currentStartAngle + arcSize);
        
        if (mode === "TYPE" && typeColors[itemText]) {
            ctx.fillStyle = typeColors[itemText];
        } else {
            ctx.fillStyle = colors[i % colors.length];
        }
        
        ctx.fill();
        ctx.strokeStyle = "#ffffff";
        ctx.lineWidth = 2.5;
        ctx.stroke();
        
        ctx.save();
        
        if (mode === "TYPE" && typeTextColors[itemText]) {
            ctx.fillStyle = typeTextColors[itemText];
        } else {
            ctx.fillStyle = "#333333";
        }
        
        let baseFontSize = numSegments > 15 ? 12 : 16;
        let finalFontSize = Math.round(baseFontSize * fontScale);
        
        ctx.font = `bold ${finalFontSize}px sans-serif`;
        ctx.textAlign = "right";
        
        ctx.rotate(currentStartAngle + arcSize / 2);
        ctx.fillText(itemText, canvas.width / 2 - 20, 6);
        ctx.restore();
        
        currentStartAngle += arcSize;
    }
    ctx.restore();

    drawCenterSprite();
    drawConfetti(); // 💥 축포 파티클 그리기 파이프라인 연결
}

function drawCenterSprite() {
    if (!currentSpriteImage || currentSpriteFrames.length === 0) return;
    
    const currentFrame = currentSpriteFrames[currentSpriteFrameIndex];
    if (!currentFrame || !currentFrame.frame) return;
    
    const f = currentFrame.frame;
    
    ctx.save();
    ctx.beginPath();
    ctx.arc(canvas.width / 2, canvas.height / 2, 55, 0, 2 * Math.PI);
    ctx.fillStyle = "#ffffff";
    ctx.shadowBlur = 8;
    ctx.shadowColor = "rgba(0, 0, 0, 0.15)";
    ctx.fill();
    ctx.strokeStyle = "#cbd5e1";
    ctx.lineWidth = 2.5;
    ctx.stroke();
    ctx.restore();
    
    ctx.save();
    const targetW = 84; 
    const targetH = (f.h / f.w) * targetW;
    const dx = canvas.width / 2 - targetW / 2;
    const dy = canvas.height / 2 - targetH / 2;
    
    ctx.drawImage(currentSpriteImage, f.x, f.y, f.w, f.h, dx, dy, targetW, targetH);
    ctx.restore();
}

function drawBoxSprite() {
    const spriteCanvas = document.getElementById("spriteCanvas");
    if (!spriteCanvas) return;
    const sCtx = spriteCanvas.getContext("2d");
    sCtx.clearRect(0, 0, spriteCanvas.width, spriteCanvas.height);
    
    if (!currentSpriteImage || currentSpriteFrames.length === 0) {
        document.getElementById("final-sprite-container").style.display = "none";
        return;
    }
    
    document.getElementById("final-sprite-container").style.display = "flex";
    const currentFrame = currentSpriteFrames[currentSpriteFrameIndex];
    if (!currentFrame || !currentFrame.frame) return;
    
    const f = currentFrame.frame;
    const targetW = 76;
    const targetH = (f.h / f.w) * targetW;
    const dx = spriteCanvas.width / 2 - targetW / 2;
    const dy = spriteCanvas.height / 2 - targetH / 2;
    
    sCtx.drawImage(currentSpriteImage, f.x, f.y, f.w, f.h, dx, dy, targetW, targetH);
}

// 🚀 축포 이펙트 생성기 (좌우 하단 쌍포 연출)
function triggerConfetti() {
    confettiParticles = [];
    const partyColors = ["#ff4757", "#2ed573", "#1e90ff", "#ffa502", "#ffadad", "#ffd6a5", "#fdffb6", "#caffbf", "#9bf6ff", "#a0c4ff", "#bdb2ff", "#ffc6ff"];
    
    // 왼쪽 하단 폭죽 (우상향 발사)
    for (let i = 0; i < 75; i++) {
        confettiParticles.push({
            x: 0,
            y: canvas.height,
            vx: Math.random() * 11 + 4,
            vy: -Math.random() * 16 - 12,
            gravity: 0.38,
            color: partyColors[Math.floor(Math.random() * partyColors.length)],
            size: Math.random() * 8 + 6,
            shape: Math.random() > 0.5 ? "rect" : "circle",
            rotation: Math.random() * Math.PI * 2,
            rotationSpeed: (Math.random() - 0.5) * 0.25,
            opacity: 1,
            fadeSpeed: Math.random() * 0.006 + 0.004
        });
    }
    
    // 오른쪽 하단 폭죽 (좌상향 발사)
    for (let i = 0; i < 75; i++) {
        confettiParticles.push({
            x: canvas.width,
            y: canvas.height,
            vx: -Math.random() * 11 - 4,
            vy: -Math.random() * 16 - 12,
            gravity: 0.38,
            color: partyColors[Math.floor(Math.random() * partyColors.length)],
            size: Math.random() * 8 + 6,
            shape: Math.random() > 0.5 ? "rect" : "circle",
            rotation: Math.random() * Math.PI * 2,
            rotationSpeed: (Math.random() - 0.5) * 0.25,
            opacity: 1,
            fadeSpeed: Math.random() * 0.006 + 0.004
        });
    }
}

// 🎨 축포 프레임 실시간 업데이트 및 렌더링
function drawConfetti() {
    for (let i = confettiParticles.length - 1; i >= 0; i--) {
        let p = confettiParticles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.vy += p.gravity;
        p.vx *= 0.985; // 공기 저항
        p.rotation += p.rotationSpeed;
        p.opacity -= p.fadeSpeed;
        
        // 화면을 완전히 벗어나거나 투명해진 파티클 소멸
        if (p.opacity <= 0 || p.y > canvas.height + 20 || p.x < -20 || p.x > canvas.width + 20) {
            confettiParticles.splice(i, 1);
            continue;
        }
        
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rotation);
        ctx.fillStyle = p.color;
        ctx.globalAlpha = p.opacity;
        
        ctx.beginPath();
        if (p.shape === "circle") {
            ctx.arc(0, 0, p.size / 2, 0, Math.PI * 2);
            ctx.fill();
        } else {
            ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
        }
        ctx.restore();
    }
}

// 🖼️ 스프라이트 로더
function loadPokemonSprite(pokemonNo) {
    if (!pokemonNo) { clearSprite(); return; }
    
    const cleanNo = String(pokemonNo).replace(/[^0-9]/g, '');
    if (!cleanNo) { clearSprite(); return; }
    
    const num = parseInt(cleanNo, 10);
    const formats = [cleanNo]; 
    if (!isNaN(num)) {
        formats.push(String(num)); 
        formats.push(String(num).padStart(3, '0')); 
        formats.push(String(num).padStart(4, '0')); 
    }
    
    const uniqueFormats = [...new Set(formats)];
    let formatIndex = 0;
    
    function tryFetch() {
        if (formatIndex >= uniqueFormats.length) {
            console.warn(`[이미지 오류] 도감번호 ${pokemonNo} 스프라이트 자산을 찾지 못했습니다.`);
            clearSprite();
            drawWheel();
            return;
        }
        
        const currentId = uniqueFormats[formatIndex];
        const jsonUrl = `pokerogue-asset/images/pokemon/${currentId}.json`;
        const pngUrl = `pokerogue-asset/images/pokemon/${currentId}.png`;
        
        fetch(jsonUrl)
            .then(res => {
                if (!res.ok) throw new Error("404");
                return res.json();
            })
            .then(data => {
                let frames = [];
                if (data.textures && data.textures[0] && data.textures[0].frames) {
                    const f = data.textures[0].frames;
                    frames = Array.isArray(f) ? f : Object.values(f);
                } else if (data.frames) {
                    frames = Array.isArray(data.frames) ? data.frames : Object.values(data.frames);
                }
                
                if (!frames || frames.length === 0) throw new Error("Empty Frames");
                frames.sort((a, b) => String(a.filename).localeCompare(String(b.filename)));
                
                const img = new Image();
                img.onload = () => {
                    currentSpriteImage = img;
                    currentSpriteFrames = frames;
                    currentSpriteFrameIndex = 0;
                    lastFrameTime = performance.now();
                    drawWheel();
                    drawBoxSprite();
                };
                img.src = pngUrl;
            })
            .catch(() => {
                formatIndex++;
                tryFetch();
            });
    }
    
    tryFetch();
}

function clearSprite() {
    currentSpriteImage = null;
    currentSpriteFrames = [];
    currentSpriteFrameIndex = 0;
    confettiParticles = []; // 새로운 스핀 구동 시 기존 축포 잔상 초기화
    const container = document.getElementById("final-sprite-container");
    if (container) container.style.display = "none";
}

function syncEditorPanel() {
    const panel = document.getElementById("editorPanel");
    const container = document.getElementById("editorItemsContainer");
    const badge = document.getElementById("editorModeBadge");
    
    if (mode === "NONE") { panel.style.display = "none"; return; }
    panel.style.display = "block";
    badge.innerText = `${mode} 편집 구역`;
    
    container.innerHTML = "";
    currentItems.forEach((item, index) => {
        container.innerHTML += `
            <div class="editor-item-chip">
                <div class="chip-left">
                    <span style="font-weight:bold;">${item.text}</span>
                    <span>(비중: <input type="number" class="weight-input" min="1" max="100" value="${item.weight}" onchange="updateItemWeight(${index}, this.value)">)</span>
                </div>
                <button class="delete-chip-btn" onclick="removeItemFromEditor(${index})">X 제외</button>
            </div>
        `;
    });
}

function updateItemWeight(index, val) {
    let num = parseInt(val);
    if (isNaN(num) || num < 1) num = 1;
    currentItems[index].weight = num;
    drawWheel();
    updateLivePointerText();
}

function removeItemFromEditor(index) {
    currentItems.splice(index, 1);
    drawWheel();
    updateLivePointerText();
    syncEditorPanel();
}

function addItemToEditor() {
    const input = document.getElementById("newInputText");
    const val = input.value.trim();
    if (!val) return;
    
    if (currentItems.some(item => item.text === val)) {
        alert("이미 존재하는 항목입니다.");
        return;
    }
    
    currentItems.push({ text: val, weight: 1 });
    input.value = "";
    drawWheel();
    updateLivePointerText();
    syncEditorPanel();
}

function onChangeMainVersion() {
    const mainSelect = document.getElementById("versionSelect");
    const optionContainer = document.getElementById("optionContainer");
    const dlcZone = document.getElementById("dlcCheckboxZone");
    const confirmBtn = document.getElementById("btn-confirm-version");
    
    chosenMainVersion = mainSelect.value;
    dlcZone.innerHTML = ""; 
    document.getElementById("rarityCheck").checked = false; 
    
    if(!chosenMainVersion) {
        optionContainer.style.display = "none";
        confirmBtn.disabled = true;
        document.getElementById("final-info").innerText = "먼저 상단에서 게임 버전을 선택해 주세요!";
        return;
    }
    
    optionContainer.style.display = "block";
    confirmBtn.disabled = false;
    
    if (chosenMainVersion === "소드실드") {
        dlcZone.innerHTML += `<label><input type="checkbox" value="갑옷섬" onchange="calculatePreviewCount()"> 🏝️ 갑옷섬</label>`;
        dlcZone.innerHTML += `<label><input type="checkbox" value="왕관설원" onchange="calculatePreviewCount()"> 🏔️ 왕관설원</label>`;
    } else if (chosenMainVersion === "스바") {
        dlcZone.innerHTML += `<label><input type="checkbox" value="북신" onchange="calculatePreviewCount()"> 👺 북신</label>`;
        dlcZone.innerHTML += `<label><input type="checkbox" value="블루베리" onchange="calculatePreviewCount()"> 🫐 블루베리</label>`;
    } else {
        dlcZone.innerHTML = `<span style="font-size:13px; color:#aaa; font-weight:normal;">추가 DLC 없음</span>`;
    }
    
    calculatePreviewCount();
}

function filterCoreLogic(targetKeys, allowRarity) {
    return svPokemonDatabase.filter(p => {
        if (p.isBase !== true) return false;
        const isCorrectVersion = targetKeys.some(key => p.versions[key] === true);
        if (!isCorrectVersion) return false;
        if (!allowRarity && (p.rarity === "전설" || p.rarity === "환상")) return false;
        return true;
    });
}

function calculatePreviewCount() {
    const targetKeys = getSelectedVersionKeys();
    const allowRarity = document.getElementById("rarityCheck").checked;
    const previewDB = filterCoreLogic(targetKeys, allowRarity);
    let infoText = `[${targetKeys.join(' + ')}]`;
    if(allowRarity) infoText += ` + [전설/환상포함]`;
    document.getElementById("final-info").innerText = `${infoText} 선택됨 (기준 포켓몬 총 ${previewDB.length}마리). 확정 후 시작하세요!`;
}

function getSelectedVersionKeys() {
    const keys = [chosenMainVersion];
    const checkboxes = document.querySelectorAll("#dlcCheckboxZone input[type='checkbox']");
    checkboxes.forEach(cb => { if(cb.checked) keys.push(cb.value); });
    return keys;
}

function lockAndLoadDatabase() {
    const targetKeys = getSelectedVersionKeys();
    const allowRarity = document.getElementById("rarityCheck").checked;
    
    versionFilteredDB = filterCoreLogic(targetKeys, allowRarity);
    
    document.getElementById("versionSelect").disabled = true;
    document.getElementById("rarityCheck").disabled = true;
    document.querySelectorAll("#dlcCheckboxZone input").forEach(input => input.disabled = true);
    document.getElementById("btn-confirm-version").disabled = true;
    
    document.getElementById("final-info").innerText = `최종 ${versionFilteredDB.length}마리의 진화 기준 포켓몬이 준비되었습니다. 1단계 세대를 굴리세요!`;
    initGenWheel();
}

function initGenWheel() {
    mode = "GEN";
    document.getElementById("box-gen").classList.add("active");
    document.getElementById("btn-gen").disabled = false;
    
    const availableGens = [...new Set(versionFilteredDB.map(p => p.gen))].sort((a,b)=>a-b);
    currentItems = availableGens.map(g => ({ text: `${g}세대`, weight: 1 }));
    currentAngle = 0;
    drawWheel();
    updateLivePointerText();
    syncEditorPanel();
}

function spinToSelect(callback) {
    if (isSpinning) return;
    isSpinning = true;
    let velocity = Math.random() * 0.3 + (mode === "POKE" ? 0.6 : 0.4); 
    const friction = mode === "POKE" ? 0.985 : 0.98; 
    
    function animate() {
        currentAngle += velocity;
        velocity *= friction;
        drawWheel();
        updateLivePointerText();
        
        if (velocity < 0.0015) {
            isSpinning = false;
            const finalIdx = getTargetIndex();
            callback(finalIdx);
        } else {
            requestAnimationFrame(animate);
        }
    }
    animate();
}

function startGenSpin() {
    if (isSpinning) return;
    
    clearSprite(); 
    mode = "GEN";
    chosenGen = null;
    chosenType = null;
    finalCandidates = [];
    
    document.getElementById("res-gen").innerText = "? 세대";
    document.getElementById("res-type").innerText = "? 타입";
    document.getElementById("res-poke").innerText = "? 마리";
    document.getElementById("final-name").innerText = "준비 완료";
    
    ["box-gen", "box-type", "box-poke"].forEach(id => document.getElementById(id).classList.remove("active"));
    document.getElementById("box-gen").classList.add("active");
    
    document.getElementById("btn-gen").disabled = true;
    document.getElementById("btn-type").disabled = true;
    document.getElementById("btn-poke").disabled = true;
    
    spinToSelect((index) => {
        const matchResult = currentItems[index].text.match(/\d+/);
        chosenGen = matchResult ? parseInt(matchResult[0]) : 1; 

        document.getElementById("res-gen").innerText = `🎉 ${currentItems[index].text}`;
        prepareTypeStage();
    });
}

function prepareTypeStage() {
    const genFiltered = versionFilteredDB.filter(p => p.gen === chosenGen);
    const availableTypes = [...new Set(genFiltered.flatMap(p => p.types))].sort();
    
    currentItems = availableTypes.map(t => ({ text: t, weight: 1 }));
    currentAngle = 0;
    mode = "TYPE";
    drawWheel();
    updateLivePointerText();
    syncEditorPanel();
    
    ["box-gen", "box-type", "box-poke"].forEach(id => document.getElementById(id).classList.remove("active"));
    document.getElementById("box-type").classList.add("active");
    
    document.getElementById("btn-gen").disabled = false;
    document.getElementById("btn-type").disabled = false;
    document.getElementById("btn-poke").disabled = true;
}

function startTypeSpin() {
    if (isSpinning) return;
    
    clearSprite(); 
    mode = "TYPE";
    chosenType = null;
    finalCandidates = [];
    
    document.getElementById("res-type").innerText = "? 타입";
    document.getElementById("res-poke").innerText = "? 마리";
    document.getElementById("final-name").innerText = "준비 완료";
    
    ["box-gen", "box-type", "box-poke"].forEach(id => document.getElementById(id).classList.remove("active"));
    document.getElementById("box-type").classList.add("active");
    
    document.getElementById("btn-gen").disabled = true; 
    document.getElementById("btn-type").disabled = true;
    document.getElementById("btn-poke").disabled = true;

    spinToSelect((index) => {
        chosenType = currentItems[index].text;
        document.getElementById("res-type").innerText = `🎉 ${chosenType}`;
        preparePokeStage();
    });
}

function preparePokeStage() {
    finalCandidates = versionFilteredDB.filter(p => p.gen === chosenGen && p.types.includes(chosenType));
    
    if(finalCandidates.length === 0) {
        currentItems = [{ text: "해당 조건 포켓몬 없음", weight: 1 }];
    } else {
        currentItems = finalCandidates.map(p => ({ text: p.name, weight: 1 }));
    }
    
    currentAngle = 0;
    mode = "POKE";
    drawWheel();
    updateLivePointerText();
    syncEditorPanel();
    
    document.getElementById("res-poke").innerText = `${finalCandidates.length}마리`;
    ["box-gen", "box-type", "box-poke"].forEach(id => document.getElementById(id).classList.remove("active"));
    document.getElementById("box-poke").classList.add("active");
    
    document.getElementById("btn-gen").disabled = false;
    document.getElementById("btn-type").disabled = false;
    document.getElementById("btn-poke").disabled = false;
}

function startPokeSpin() {
    if (isSpinning) return;
    
    clearSprite(); 
    document.getElementById("btn-gen").disabled = true;
    document.getElementById("btn-type").disabled = true;
    document.getElementById("btn-poke").disabled = true;
    
    spinToSelect((index) => {
        const winningName = currentItems[index].text;
        document.getElementById("res-poke").innerText = `🎉 ${winningName}`;
        
        const lucky = finalCandidates.find(p => p.name === winningName);
        
        if(lucky) {
            let badges = [];
            if(lucky.mega) badges.push("🧬메가진화");
            if(lucky.regionForm && lucky.regionForm !== "일반" && lucky.regionForm !== "") badges.push(`🗺️${lucky.regionForm}폼`);
            if(lucky.rarity && lucky.rarity !== "") badges.push(`⭐${lucky.rarity}`);
            
            const pokeId = lucky.no || lucky.id || lucky.number || lucky.pokedexNo || lucky.pokedexId;
            
            document.getElementById("final-name").innerText = lucky.name + (badges.length ? ` (${badges.join(' ')})` : '');
            document.getElementById("final-info").innerText = `🏆 도감번호 ${pokeId || '?'} | [${lucky.gen}세대] ${lucky.types.join('/')} 타입 최종 낙점!`;
            
            if (pokeId) {
                loadPokemonSprite(pokeId);
                playPokemonCry(pokeId);
            } else {
                console.error("포켓몬 고유 ID 속성을 식별할 수 없습니다:", lucky);
            }
        } else {
            document.getElementById("final-name").innerText = winningName;
            document.getElementById("final-info").innerText = `🔧 커스텀 지정 항목 당첨`;
            clearSprite();
        }
        
        // 💥 [추가된 기능] 최종 포켓몬 선택 완료 시 축포 이펙트 발사!
        triggerConfetti();
        
        document.getElementById("btn-gen").disabled = false;
        document.getElementById("btn-type").disabled = false;
        document.getElementById("btn-poke").disabled = false; 
    });
}

function resetAll() {
    if (isSpinning) return;
    clearSprite(); 
    chosenGen = null; chosenType = null; finalCandidates = []; chosenMainVersion = "";
    
    document.getElementById("versionSelect").disabled = false;
    document.getElementById("versionSelect").value = "";
    document.getElementById("rarityCheck").disabled = false;
    document.getElementById("rarityCheck").checked = false;
    
    document.getElementById("optionContainer").style.display = "none";
    document.getElementById("dlcCheckboxZone").innerHTML = "";
    document.getElementById("btn-confirm-version").disabled = true;
    
    document.getElementById("res-gen").innerText = "? 세대";
    document.getElementById("res-type").innerText = "? 타입";
    document.getElementById("res-poke").innerText = "? 마리";
    document.getElementById("final-name").innerText = "준비 완료";
    document.getElementById("final-info").innerText = "먼저 상단에서 게임 버전을 선택해 주세요!";
    
    ["box-gen", "box-type", "box-poke"].forEach(id => document.getElementById(id).classList.remove("active"));
    ["btn-gen", "btn-type", "btn-poke"].forEach(id => document.getElementById(id).disabled = true);
    
    currentItems = [];
    mode = "NONE";
    drawWheel();
    updateLivePointerText();
    syncEditorPanel();
}

// 🔧 실시간 메인 애니메이션 루프 (축포 구동을 위한 고주파 렌더러 결합 업데이트)
function spriteAnimationLoop() {
    requestAnimationFrame(spriteAnimationLoop);
    
    let needsRedraw = false;
    
    // 1. 박스 우측 하단 스프라이트 시트 타이머 프레임 체크 (100ms 단위)
    if (currentSpriteImage && currentSpriteFrames.length > 0) {
        const now = performance.now();
        if (now - lastFrameTime > frameDuration) {
            currentSpriteFrameIndex = (currentSpriteFrameIndex + 1) % currentSpriteFrames.length;
            lastFrameTime = now;
            needsRedraw = true;
            drawBoxSprite();
        }
    }
    
    // 2. 활성화된 축포 파티클이 있다면 매 프레임(60fps) 강제 캔버스 드로잉 요청
    if (confettiParticles.length > 0) {
        needsRedraw = true;
    }
    
    // 3. 룰렛이 돌고 있지 않는 유휴 상태일 때 변경 레이어 병합 화면 갱신
    if (needsRedraw && !isSpinning) {
        drawWheel();
    }
}
requestAnimationFrame(spriteAnimationLoop);

// ==========================================================
// 💡 신규 추가: 디버그 모니터 온/오프 및 푸터 상세 토글 자바스크립트 로직
// ==========================================================
let isDebugInitialized = false;
let isDebugAnimating = false;

function toggleDebugMonitor() {
    const container = document.getElementById("debug-container");
    const btn = document.getElementById("btn-toggle-debug");
    
    if (container.style.display === "none") {
        container.style.display = "block";
        btn.innerText = "🛠️ 피카츄 끄기";
        btn.style.backgroundColor = "#ef4444"; // 온(On) 상태일 때는 빨간색으로 변경
        
        // pokemonData.js 또는 외부 스크립트에 선언되어 있을 디버그 초기화/애니메이션 함수 호출 제어
        if (!isDebugInitialized) {
            if (typeof initDebugMonitor === "function") {
                initDebugMonitor();
            } else {
                document.getElementById("debug-status").innerText = "🟢 활성화됨 (렌더링 대기)";
            }
            isDebugInitialized = true;
        } else {
            // 전역 플래그를 변경하여 애니메이션 루프를 안전하게 복구
            window.isDebugAnimating = true; 
            if (typeof animateDebugFrame === "function") {
                animateDebugFrame();
            }
        }
    } else {
        container.style.display = "none";
        btn.innerText = "🛠️ 피카츄 켜기";
        btn.style.backgroundColor = "#3b82f6"; // 기본 파란색 복구
        window.isDebugAnimating = false; // 루프 플래그 해제하여 리소스 점유 방지
    }
}

function toggleFooterDetails() {
    const details = document.getElementById("footer-details");
    const btn = document.getElementById("btn-toggle-footer");
    
    if (details.style.display === "none") {
        details.style.display = "flex";
        btn.innerText = "📄 법적 면책 조항 및 출처 접기 (▲)";
    } else {
        details.style.display = "none";
        btn.innerText = "📄 법적 면책 조항 및 출처 보기 (▼)";
    }
}
</script>
</body>
</html>